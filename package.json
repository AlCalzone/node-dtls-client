{
  "name": "node-dtls-client",
  "version": "2.0.2",
  "description": "DTLS protocol implementation for Node.js written in TypeScript.",
  "type": "module",
  "main": "./build/dtls.js",
  "exports": {
    ".": {
      "types": "./build/dtls.d.ts",
      "default": "./build/dtls.js"
    }
  },
  "types": "./build/dtls.d.ts",
  "author": {
    "name": "AlCalzone",
    "email": "d.griesel@gmx.net"
  },
  "license": "MIT",
  "homepage": "https://github.com/AlCalzone/node-dtls-client",
  "files": [
    "build/"
  ],
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/debug": "4.1.13",
    "@types/node": "^22.19.15",
    "@types/semver": "^7.7.1",
    "@types/yargs": "^17.0.20",
    "rimraf": "^6.1.3",
    "oxlint": "^1.57.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.2",
    "yargs": "^17.7.2"
  },
  "dependencies": {
    "debug": "^4.3.4",
    "semver": "^7.7.4"
  },
  "optionalDependencies": {
    "node-aead-crypto": "^3.0.1"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlCalzone/node-dtls-client.git"
  },
  "scripts": {
    "build": "tsc",
    "prebuild": "rimraf ./build",
    "prepack": "npm run build",
    "watch": "tsc --watch",
    "test:ts": "vitest run",
    "test:watch": "vitest",
    "test": "npm run test:ts",
    "lint:ts": "oxlint --deny-warnings --vitest-plugin src",
    "lint": "npm run lint:ts",
    "release": "release-script"
  },
  "readme": "README.md"
}
