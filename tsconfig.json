{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "noEmitOnError": true,
        "noUnusedLocals": true,
        "outDir": "build/",
        "removeComments": false,
        "rootDir": "src",
        "strictNullChecks": false, // This is gonna take some work to enable
        "stripInternal": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/*.test.ts",
        "build/**",
        "node_modules/**"
    ]
}
